{
  "manifest_version": 3,
  "name": "Send to ComfyUI",
  "version": "1.3",
  "description": "Send images from the web and trigger your active ComfyUI tab.",
  "permissions": [
    "contextMenus",
    "declarativeNetRequest",
    "tabs",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>",
    "http://127.0.0.1:8188/*"
  ],
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "ComfyUI Remote",
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "comfy_cors_rules",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  },
  "background": {
    "service_worker": "background.js"
  }
}